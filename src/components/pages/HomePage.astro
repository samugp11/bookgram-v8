---
---
<section class="page active" id="page-home">
  <header class="hero">
    <div class="hero__bg-shapes">
      <div class="hero__shape hero__shape--1"></div>
      <div class="hero__shape hero__shape--2"></div>
    </div>
    <div class="container hero__grid">
      <div class="hero__content">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          Más de 2,500 libros disponibles
        </div>
        <h1 class="hero__title">Descubre tu próxima <span>gran lectura</span></h1>
        <p class="hero__description">Explora miles de libros, organiza tu biblioteca personal, comparte reseñas y conecta con una comunidad apasionada por la lectura.</p>
        <div class="hero__actions">
          <button class="btn btn--primary btn--lg" onclick="navigateTo('catalog')">
            Explorar catálogo
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
          <button class="btn btn--outline btn--lg" onclick="navigateTo('community')">Ver comunidad</button>
        </div>
        <div class="hero__stats">
          <div class="hero__stat"><div class="hero__stat-number">12K+</div><div class="hero__stat-label">Lectores activos</div></div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat"><div class="hero__stat-number">2.5K</div><div class="hero__stat-label">Libros en catálogo</div></div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat"><div class="hero__stat-number">850+</div><div class="hero__stat-label">Reseñas publicadas</div></div>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__book-stack">
          <div class="hero__book-card"><img src="https://images.unsplash.com/photo-1544947950-fa07a98d237f?w=400&h=600&fit=crop" alt="Libro 1" loading="eager" width="200" height="290"></div>
          <div class="hero__book-card"><img src="https://images.unsplash.com/photo-1512820790803-83ca734da794?w=400&h=600&fit=crop" alt="Libro 2" loading="eager" width="200" height="290"></div>
          <div class="hero__book-card"><img src="https://images.unsplash.com/photo-1543002588-bfa74002ed7e?w=400&h=600&fit=crop" alt="Libro 3" loading="eager" width="200" height="290"></div>
          <div class="hero__float-card hero__float-card--top">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <div class="hero__float-card-text"><h4>4.9 valoración</h4><p>850+ reseñas</p></div>
          </div>
          <div class="hero__float-card hero__float-card--bottom">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <div class="hero__float-card-text"><h4>+35 nuevos</h4><p>Esta semana</p></div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Características</span>
        <h2 class="section-title">Todo lo que necesitas para tu lectura</h2>
        <p class="section-subtitle">Herramientas diseñadas para amantes de los libros</p>
      </div>
      <div class="features-grid">
        <article class="feature-card">
          <div class="feature-card__icon feature-card__icon--cobalt">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h3 class="feature-card__title">Biblioteca Personal</h3>
          <p class="feature-card__desc">Organiza tus libros leídos, pendientes y favoritos con seguimiento de progreso y meta anual.</p>
        </article>
        <article class="feature-card">
          <div class="feature-card__icon feature-card__icon--accent">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="feature-card__title">Reseñas y valoraciones</h3>
          <p class="feature-card__desc">Comparte tu opinión sobre los libros que has leído y descubre qué piensan otros lectores.</p>
        </article>
        <article class="feature-card">
          <div class="feature-card__icon feature-card__icon--amber">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          </div>
          <h3 class="feature-card__title">Retos de lectura</h3>
          <p class="feature-card__desc">Participa en desafíos mensuales, establece metas de lectura y gana insignias exclusivas.</p>
        </article>
        <article class="feature-card">
          <div class="feature-card__icon feature-card__icon--sage">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="feature-card__title">Clubes de lectura</h3>
          <p class="feature-card__desc">Únete a clubes temáticos, participa en discusiones y conecta con lectores afines.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Tendencias</span>
        <h2 class="section-title">Libros más populares</h2>
        <p class="section-subtitle">Los títulos que están conquistando a nuestra comunidad</p>
      </div>
      <div class="trending-scroll" id="trendingScroll"></div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Testimonios</span>
        <h2 class="section-title">Lo que dicen nuestros lectores</h2>
      </div>
      <div class="testimonials-grid">
        <article class="testimonial-card">
          <div class="testimonial-card__stars stars">★★★★★</div>
          <p class="testimonial-card__text">"BookGram transformó mi forma de organizar mis lecturas. La comunidad es increíble y siempre descubro libros nuevos."</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar"><img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=96&h=96&fit=crop&crop=face" alt="María García" loading="lazy" width="48" height="48"></div>
            <div><div class="testimonial-card__name">María García</div><div class="testimonial-card__role">Lectora ávida · 120 libros</div></div>
          </div>
        </article>
        <article class="testimonial-card">
          <div class="testimonial-card__stars stars">★★★★★</div>
          <p class="testimonial-card__text">"Los retos de lectura me motivan a leer más. Llevo 45 libros este año gracias a esta plataforma."</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar"><img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=96&h=96&fit=crop&crop=face" alt="Carlos Ruiz" loading="lazy" width="48" height="48"></div>
            <div><div class="testimonial-card__name">Carlos Ruiz</div><div class="testimonial-card__role">Club de Sci-Fi · 45 libros</div></div>
          </div>
        </article>
        <article class="testimonial-card">
          <div class="testimonial-card__stars stars">★★★★★</div>
          <p class="testimonial-card__text">"La mejor plataforma para descubrir autores independientes. Las recomendaciones son excelentes."</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar"><img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=96&h=96&fit=crop&crop=face" alt="Laura Martín" loading="lazy" width="48" height="48"></div>
            <div><div class="testimonial-card__name">Laura Martín</div><div class="testimonial-card__role">Blogger literaria · 89 libros</div></div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="newsletter">
        <div class="newsletter__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h2 class="newsletter__title">Únete a nuestra newsletter</h2>
        <p class="newsletter__subtitle">Recibe recomendaciones semanales y novedades literarias en tu correo</p>
        <form class="newsletter__form" onsubmit="handleNewsletter(event)">
          <input type="email" class="newsletter__input" placeholder="tu@email.com" required aria-label="Tu email">
          <button type="submit" class="newsletter__btn">Suscribirme</button>
        </form>
      </div>
    </div>
  </section>
</section>
