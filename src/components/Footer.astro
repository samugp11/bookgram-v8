        </div>
      </div>
      <div>
        <h4 class="footer__col-title">Explorar</h4>
        <ul class="footer__links">
          <li><a href="#" onclick="navigateTo('catalog')">Catálogo</a></li>
          <li><a href="#" onclick="navigateTo('library')">Mi Biblioteca</a></li>
          <li><a href="#" onclick="navigateTo('blog')">Blog</a></li>
          <li><a href="#" onclick="navigateTo('community')">Comunidad</a></li>
          <li><a href="#" onclick="navigateTo('contact')">Contacto</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer__col-title">Comunidad</h4>
        <ul class="footer__links">
          <li><a href="#" onclick="navigateTo('community')">Clubes de lectura</a></li>
          <li><a href="#" onclick="navigateTo('community')">Retos mensuales</a></li>
          <li><a href="#" onclick="navigateTo('community')">Actividad</a></li>
          <li><a href="#" onclick="navigateTo('community')">Top lectores</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer__col-title">Soporte</h4>
        <ul class="footer__links">
          <li><a href="#" onclick="navigateTo('contact')">Contacto</a></li>
          <li><a href="#" onclick="navigateTo('contact')">Preguntas frecuentes</a></li>
          <li><a href="#">Privacidad</a></li>
          <li><a href="#">Términos de uso</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <p class="footer__copyright">© 2026 BookGram. Hecho para lectores.</p>
      <div class="footer__bottom-links">
        <a href="#">Privacidad</a>
        <a href="#">Términos</a>
        <a href="#">Cookies</a>
      </div>
    </div>
  </div>
</footer>
<div class="toast-container" id="toastContainer"></div>
