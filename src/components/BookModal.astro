<div class="modal-overlay" id="bookModal" onclick="closeBookModalBackdrop(event)" role="dialog" aria-modal="true" aria-labelledby="bookModalTitle">
  <div class="modal-box">
    <button class="modal-close" onclick="closeBookModal()" aria-label="Cerrar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="book-modal__grid" id="bookModalBody"></div>
  </div>
</div>
