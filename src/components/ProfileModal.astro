---
---
<!-- ══ ONBOARDING (se muestra si el perfil está vacío) ══ -->
<div class="onboarding" id="onboarding">
  <div class="onboarding__card">
    <div class="onboarding__logo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    </div>
    <h1 class="onboarding__title">Bienvenido a BookGram</h1>
    <p class="onboarding__subtitle">Crea tu perfil de lector en segundos</p>

    <!-- Step 1: name + username -->
    <div class="onboarding__step active" id="ob-step-1">
      <div class="form-group" style="text-align:left">
        <label class="form-label">¿Cómo te llamas?</label>
        <input type="text" class="form-input" id="obName" placeholder="Ej. Ana García" maxlength="40" autocomplete="name">
      </div>
      <div class="form-group" style="text-align:left;margin-top:1rem">
        <label class="form-label">Elige un nombre de usuario</label>
        <div class="input-prefix-wrap">
          <span class="input-prefix">@</span>
          <input type="text" class="form-input input-prefix-input" id="obUsername" placeholder="anareads" maxlength="30">
        </div>
      </div>
      <button class="btn btn--primary btn--lg" style="width:100%;margin-top:1.5rem" onclick="obNext(1)">Continuar</button>
    </div>

    <!-- Step 2: avatar -->
    <div class="onboarding__step" id="ob-step-2">
      <p class="onboarding__step-label">Elige tu avatar</p>
      <div class="onboarding__avatars" id="obAvatarGrid">
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=100&h=100&fit=crop&crop=face" alt="Avatar 1"></div>
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&crop=face" alt="Avatar 2"></div>
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face" alt="Avatar 3"></div>
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop&crop=face" alt="Avatar 4"></div>
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop&crop=face" alt="Avatar 5"></div>
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&h=100&fit=crop&crop=face" alt="Avatar 6"></div>
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop&crop=face" alt="Avatar 7"></div>
        <div class="avatar-option" onclick="obSelectAvatar(this,'https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=200&h=200&fit=crop&crop=face')"><img src="https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=100&h=100&fit=crop&crop=face" alt="Avatar 8"></div>
      </div>
      <button class="btn btn--primary btn--lg" style="width:100%;margin-top:1.5rem" onclick="obNext(2)">Continuar</button>
      <button class="btn btn--ghost btn--sm" style="width:100%;margin-top:0.5rem" onclick="obBack(2)">Atrás</button>
    </div>

    <!-- Step 3: goal + genres -->
    <div class="onboarding__step" id="ob-step-3">
      <div class="form-group" style="text-align:left">
        <label class="form-label">Meta de lectura para 2026 (libros)</label>
        <input type="number" class="form-input" id="obGoal" value="24" min="1" max="365">
      </div>
      <div style="margin-top:1rem;text-align:left">
        <label class="form-label">Géneros favoritos (elige hasta 3)</label>
        <div class="ob-genres" id="obGenres">
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'Ficción')">Ficción</button>
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'Fantasía')">Fantasía</button>
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'Ciencia Ficción')">Ciencia Ficción</button>
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'Misterio')">Misterio</button>
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'Romance')">Romance</button>
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'No Ficción')">No Ficción</button>
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'Ciencia')">Ciencia</button>
          <button class="ob-genre-btn" onclick="obToggleGenre(this,'Historia')">Historia</button>
        </div>
      </div>
      <button class="btn btn--primary btn--lg" style="width:100%;margin-top:1.5rem" onclick="obFinish()">Empezar a leer</button>
      <button class="btn btn--ghost btn--sm" style="width:100%;margin-top:0.5rem" onclick="obBack(3)">Atrás</button>
    </div>

    <div class="onboarding__progress">
      <div class="onboarding__dot active" id="obDot1"></div>
      <div class="onboarding__dot" id="obDot2"></div>
      <div class="onboarding__dot" id="obDot3"></div>
    </div>
  </div>
</div>

<!-- ══ PROFILE MODAL ══ -->
<div class="modal-overlay" id="profileModal" onclick="closeProfileOnBackdrop(event)">
  <div class="modal-box modal-box--profile" role="dialog" aria-modal="true" aria-labelledby="profileModalTitle">
    <button class="modal-close" onclick="closeProfileModal()" aria-label="Cerrar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div id="profileModalBody"></div>
  </div>
</div>

<!-- ══ EDIT PROFILE MODAL ══ -->
<div class="modal-overlay" id="editProfileModal" onclick="closeEditProfileOnBackdrop(event)">
  <div class="modal-box" role="dialog" aria-modal="true" aria-label="Editar perfil">
    <div class="modal-header">
      <h2 class="modal-title">Editar perfil</h2>
      <button class="modal-close" onclick="closeEditProfile()" aria-label="Cerrar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="edit-avatar-section">
        <img src="" alt="Avatar actual" id="editAvatarPreview" class="edit-avatar-preview">
        <p class="edit-avatar-label">Selecciona un avatar</p>
        <div class="avatar-grid" id="editAvatarGrid">
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=80&h=80&fit=crop&crop=face" alt="Avatar 1"></div>
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" alt="Avatar 2"></div>
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop&crop=face" alt="Avatar 3"></div>
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=80&h=80&fit=crop&crop=face" alt="Avatar 4"></div>
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=80&h=80&fit=crop&crop=face" alt="Avatar 5"></div>
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=80&h=80&fit=crop&crop=face" alt="Avatar 6"></div>
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=80&h=80&fit=crop&crop=face" alt="Avatar 7"></div>
          <div class="avatar-option" data-url="https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=200&h=200&fit=crop&crop=face" onclick="selectAvatar(this,this.dataset.url)"><img src="https://images.unsplash.com/photo-1570295999919-56ceb5ecca61?w=80&h=80&fit=crop&crop=face" alt="Avatar 8"></div>
        </div>
      </div>
      <div class="edit-fields">
        <div class="form-group">
          <label class="form-label" for="editName">Nombre</label>
          <input type="text" class="form-input" id="editName" placeholder="Tu nombre" maxlength="40">
        </div>
        <div class="form-group">
          <label class="form-label" for="editUsername">Usuario</label>
          <div class="input-prefix-wrap">
            <span class="input-prefix">@</span>
            <input type="text" class="form-input input-prefix-input" id="editUsername" placeholder="usuario" maxlength="30">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label" for="editBio">Biografía</label>
          <textarea class="form-textarea" id="editBio" rows="3" placeholder="Cuéntanos algo sobre ti como lector..." maxlength="200"></textarea>
          <span class="form-hint">Máximo 200 caracteres</span>
        </div>
        <div class="form-group">
          <label class="form-label" for="editGoal">Meta de lectura 2026 (libros)</label>
          <input type="number" class="form-input" id="editGoal" min="1" max="365" placeholder="24">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn--outline" onclick="closeEditProfile()">Cancelar</button>
      <button class="btn btn--primary" onclick="saveProfile()">Guardar cambios</button>
    </div>
  </div>
</div>

<!-- ══ SETTINGS MODAL ══ -->
<div class="modal-overlay" id="settingsModal" onclick="closeSettingsOnBackdrop(event)">
  <div class="modal-box" role="dialog" aria-modal="true" aria-label="Configuración">
    <div class="modal-header">
      <h2 class="modal-title">Configuración</h2>
      <button class="modal-close" onclick="closeSettings()" aria-label="Cerrar">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="settings-section">
        <h3 class="settings-section__title">Apariencia</h3>
        <div class="settings-item">
          <div>
            <div class="settings-item__label">Modo oscuro</div>
            <div class="settings-item__sub">Cambia el tema de la interfaz</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="settingDarkMode" onchange="toggleThemeFromSettings(this)">
            <span class="toggle-switch__track"></span>
          </label>
        </div>
      </div>
      <div class="settings-section">
        <h3 class="settings-section__title">Notificaciones</h3>
        <div class="settings-item">
          <div>
            <div class="settings-item__label">Novedades del catálogo</div>
            <div class="settings-item__sub">Nuevos libros disponibles</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" checked>
            <span class="toggle-switch__track"></span>
          </label>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item__label">Actividad de la comunidad</div>
            <div class="settings-item__sub">Cuando alguien te sigue o comenta</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" checked>
            <span class="toggle-switch__track"></span>
          </label>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item__label">Newsletter semanal</div>
            <div class="settings-item__sub">Recomendaciones cada semana</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox">
            <span class="toggle-switch__track"></span>
          </label>
        </div>
      </div>
      <div class="settings-section">
        <h3 class="settings-section__title">Privacidad</h3>
        <div class="settings-item">
          <div>
            <div class="settings-item__label">Perfil público</div>
            <div class="settings-item__sub">Otros usuarios pueden ver tu perfil</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" checked>
            <span class="toggle-switch__track"></span>
          </label>
        </div>
        <div class="settings-item">
          <div>
            <div class="settings-item__label">Biblioteca visible</div>
            <div class="settings-item__sub">Tu biblioteca aparece en tu perfil</div>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" checked>
            <span class="toggle-switch__track"></span>
          </label>
        </div>
      </div>
      <div class="settings-section settings-section--danger">
        <h3 class="settings-section__title">Zona peligrosa</h3>
        <button class="btn btn--outline btn--sm" onclick="if(confirm('¿Borrar historial de lectura?'))showToast('Historial eliminado')">Borrar historial</button>
        <button class="btn btn--danger btn--sm" onclick="if(confirm('¿Eliminar tu cuenta? Esta acción no se puede deshacer.'))showToast('Cuenta eliminada')">Eliminar cuenta</button>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn--outline" onclick="closeSettings()">Cerrar</button>
      <button class="btn btn--primary" onclick="saveSettings()">Guardar</button>
    </div>
  </div>
</div>

<!-- ══ TOAST CONTAINER ══ -->
<div id="toastContainer" class="toast-container" aria-live="polite"></div>

<!-- ══ BLOG POST MODAL ══ -->
<div class="modal-overlay" id="blogModal" onclick="closeBlogOnBackdrop(event)">
  <div class="modal-box modal-box--blog" role="dialog" aria-modal="true" aria-labelledby="blogModalTitle">
    <button class="modal-close" onclick="closeBlogModal()" aria-label="Cerrar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div id="blogModalBody"></div>
  </div>
</div>
