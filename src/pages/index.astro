/* ════════════════════════════════════════
   RENDER: CATALOG
   ════════════════════════════════════════ */
let currentPage = 1;
const BOOKS_PER_PAGE = 6;
let currentFilteredBooks = [];

function renderCatalog(books) {
    currentFilteredBooks = books;
    currentPage = 1;
    renderCatalogPage();
}

function renderCatalogPage() {
    const grid = document.getElementById('catalogGrid');
    const count = document.getElementById('catalogResultCount');
    if (!grid) return;

    const total = currentFilteredBooks.length;
    const totalPages = Math.ceil(total / BOOKS_PER_PAGE);
    const start = (currentPage - 1) * BOOKS_PER_PAGE;
    const end = start + BOOKS_PER_PAGE;
    const pageBooks = currentFilteredBooks.slice(start, end);

    if (count) count.textContent = `${total} libro${total !== 1 ? 's' : ''}`;

    if (!pageBooks.length) {
        grid.innerHTML = '<p class="catalog-empty">No se encontraron libros con ese criterio.</p>';
        renderPagination(0, 0);
        return;
    }

    grid.innerHTML = pageBooks.map(book => {
        const status     = getBookStatus(book.id);
        const inLib      = !!status;
        const iconSvg    = STATUS_ICONS[status || 'none'];
        const activeClass = inLib ? 'active' : '';
        return `
        <article class="book-card-full" onclick="openBookModal(${book.id})">
            <div class="book-card-full__cover">
                <img src="${book.img}" alt="${book.title}" loading="lazy" width="200" height="280">
                <span class="book-card-full__badge badge badge--accent">${book.badge}</span>
                <button class="book-card-full__save ${activeClass}" onclick="event.stopPropagation();quickAddLibrary(${book.id},this)" aria-label="Guardar en biblioteca" title="${inLib ? STATUS_LABELS[status] : 'Añadir a biblioteca'}">${iconSvg}</button>
            </div>
            <div class="book-card-full__info">
                <h3 class="book-card-full__title">${book.title}</h3>
                <p class="book-card-full__author">${book.author}</p>
                <div class="book-card-full__footer">
                    <span class="book-card-full__price">${book.price}</span>
                    <div class="stars" style="font-size:0.8rem">★ ${book.rating}</div>
                </div>
            </div>
        </article>`;
    }).join('');

    renderPagination(currentPage, totalPages);
}

function renderPagination(page, totalPages) {
    let pag = document.getElementById('catalogPagination');
    if (!pag) {
        pag = document.createElement('div');
        pag.id = 'catalogPagination';
        document.getElementById('catalogGrid')?.after(pag);
    }
    if (totalPages <= 1) { pag.innerHTML = ''; return; }

    let pages = '';
    for (let i = 1; i <= totalPages; i++) {
        pages += `<button class="pagination__btn ${i === page ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
    }

    pag.innerHTML = `
        <div class="pagination">
            <button class="pagination__btn pagination__btn--nav" onclick="goToPage(${page - 1})" ${page === 1 ? 'disabled' : ''}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            ${pages}
            <button class="pagination__btn pagination__btn--nav" onclick="goToPage(${page + 1})" ${page === totalPages ? 'disabled' : ''}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </button>
        </div>`;
}

function goToPage(page) {
    const totalPages = Math.ceil(currentFilteredBooks.length / BOOKS_PER_PAGE);
    if (page < 1 || page > totalPages) return;
    currentPage = page;
    renderCatalogPage();
    document.getElementById('catalogGrid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

/* ════════════════════════════════════════
   RENDER: BLOG
   ════════════════════════════════════════ */
function calcularTiempoLectura(texto) {
    if (!texto) return null;
    const palabras = texto.trim().split(/\s+/).length;
    const minutos = Math.ceil(palabras / 200); // 200 palabras por minuto
    return minutos + ' min';
}

function renderBlog() {
    const grid = document.getElementById('blogGrid');
    if (!grid) return;
    grid.innerHTML = API.blogPosts.map(post => {
        const tiempoLectura = (post.content ? calcularTiempoLectura(post.content) : null) || post.readTime || '5 min';
        return `
        <article class="blog-card" onclick="openBlogPost(${post.id})">
            <div class="blog-card__img"><img src="${post.img}" alt="${post.title}" loading="lazy" width="600" height="400"></div>
            <div class="blog-card__content">
                <span class="blog-card__tag badge ${post.tagClass}">${post.tag}</span>
                <h3 class="blog-card__title">${post.title}</h3>
                <p class="blog-card__excerpt">${post.excerpt}</p>
                <div class="blog-card__footer">
                    <div class="blog-card__author">
                        <div class="blog-card__author-avatar"><img src="${post.avatar}" alt="${post.author}" loading="lazy" width="32" height="32"></div>
                        <span class="blog-card__author-name">${post.author}</span>
                    </div>
                    <span class="blog-card__read-time">${tiempoLectura} lectura</span>
                </div>
            </div>
        </article>`;
    }).join('');
}

/* ════════════════════════════════════════
