function handleNewsletter(e) { e.preventDefault(); showToast('Suscripción exitosa. Bienvenido a la newsletter.'); e.target.reset(); }
function handleContact(e) {
    e.preventDefault();

    const regexNombre = /^[a-záéíóúüñA-ZÁÉÍÓÚÜÑ\s]{2,50}$/;
    const regexEmail  = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
    const regexAsunto = /^.{3,100}$/;
    const regexMensaje = /^[\s\S]{10,1000}$/;

    const nombre  = document.getElementById('contactName');
    const email   = document.getElementById('contactEmail');
    const asunto  = document.getElementById('contactSubject');
    const mensaje = document.getElementById('contactMessage');

    let valid = true;

    function setError(input, errorId, msg) {
        const el = document.getElementById(errorId);
        if (msg) {
            input.classList.add('form-input--error');
            if (el) el.textContent = msg;
            valid = false;
        } else {
            input.classList.remove('form-input--error');
            if (el) el.textContent = '';
        }
    }

    setError(nombre, 'contactNameError',
        !nombre.value.trim() ? 'El nombre es obligatorio' :
        !regexNombre.test(nombre.value.trim()) ? 'Solo letras y espacios, entre 2 y 50 caracteres' : '');

    setError(email, 'contactEmailError',
        !email.value.trim() ? 'El email es obligatorio' :
        !regexEmail.test(email.value.trim()) ? 'Introduce un email válido' : '');

    if (asunto.value.trim() && !regexAsunto.test(asunto.value.trim())) {
        setError(asunto, 'contactSubjectError', 'El asunto debe tener entre 3 y 100 caracteres');
    } else {
        setError(asunto, 'contactSubjectError', '');
    }

    setError(mensaje, 'contactMessageError',
        !mensaje.value.trim() ? 'El mensaje es obligatorio' :
        !regexMensaje.test(mensaje.value.trim()) ? 'El mensaje debe tener entre 10 y 1000 caracteres' : '');

    if (!valid) return;

    showToast('Mensaje enviado. Te responderemos pronto.');
    e.target.reset();
    document.querySelectorAll('.form-input--error').forEach(el => el.classList.remove('form-input--error'));
}
